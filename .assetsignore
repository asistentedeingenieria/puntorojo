# Archivos y carpetas que Cloudflare Workers + Static Assets debe IGNORAR
# al deployar el sitio. Misma sintaxis que .gitignore.
#
# Sin esto, Cloudflare incluye node_modules y otros archivos pesados
# (notablemente node_modules/workerd/bin/workerd que es 118 MiB) y el
# deploy falla con "Asset too large".

# ─── Dependencias (se instalan en el build server, no van al sitio web) ───
node_modules/

# ─── Proyecto nativo Android Capacitor (no es parte del sitio web) ───
android/
ios/

# ─── Scripts de build (no son parte del sitio servido) ───
scripts/

# ─── Configuración y secretos (ya bloqueados por .gitignore pero por las dudas) ───
.git/
.github/
.firebaserc
firebase.json
firebase-messaging-sw.js.map
cors.json

# ─── Documentación y archivos del repo (no son parte del sitio web) ───
README.md
CAPACITOR-ANDROID.md
.gitignore
.gitattributes
.assetsignore

# ─── Carpetas de fuentes para iconos/splash (los .png finales sí van) ───
assets-source/
assets/play-store/

# ─── Capacitor / Node config files ───
capacitor.config.json
capacitor.config.ts
package.json
package-lock.json
yarn.lock

# ─── Cloud Functions de Firebase (se deployan separadas con firebase CLI) ───
functions/

# ─── Archivos temporales y editores ───
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.bak
*.tmp
*~

# ─── Archivos del wrapper Capacitor que NO van a la web ───
public/

# ─── Archivos de keystore (NUNCA en el sitio publico) ───
*.keystore
*.jks
*.p12

# ─── Archivos compilados de apps nativas ───
*.aab
*.apk
*.ipa
