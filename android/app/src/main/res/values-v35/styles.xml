<?xml version="1.0" encoding="utf-8"?>
<!--
  Override de styles.xml SOLO para Android 15+ (API 35).

  Android 15 fuerza edge-to-edge por default cuando targetSdk >= 35:
  el WebView dibuja DEBAJO del status bar (donde va la hora/batería)
  y DEBAJO de la navigation bar (botones de atrás/home/recientes).

  Esto causa que el logo y kebab de PUNTO ROJO arriba se monten sobre
  la hora del celular, y que los botones del sistema abajo tapen
  contenido de la app.

  windowOptOutEdgeToEdgeEnforcement=true le dice a Android: "no me
  fuerces edge-to-edge". El sistema vuelve a reservar el espacio del
  status bar y nav bar como en Android 14 y anteriores. La app dibuja
  sólo en el área segura sin overlap.

  Cuando migremos a Capacitor 7 con manejo nativo de insets, se puede
  remover este opt-out.
-->
<resources>
    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
